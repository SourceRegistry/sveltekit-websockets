{
  "name": "@sourceregistry/sveltekit-websockets",
  "version": "1.0.8",
  "description": "Typed WebSocket infrastructure for SvelteKit — per-request or continuous connections, full back-end lifecycle, and a reactive Svelte component.",
  "author": "A.P.A. Slaa (a.p.a.slaa@projectsource.nl)",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test": "npm run check && npm run test:unit -- --run",
    "docs:build": "typedoc --entryPoints src/lib/client/index.ts --entryPoints src/lib/server/index.ts --entryPoints src/lib/vite/index.ts --out docs --name \"sveltekit-websockets\" --theme default --excludePrivate --excludeProtected"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/client/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "svelte": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "svelte": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SourceRegistry/sveltekit-websockets.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "playwright": "^1.61.1",
    "publint": "^0.3.21",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/SourceRegistry/sveltekit-websockets/issues"
  },
  "homepage": "https://sourceregistry.github.io/sveltekit-websockets/",
  "dependencies": {
    "devalue": "^5.8.1",
    "ws": "^8.21.0"
  },
  "overrides": {
    "cookie": "^0.7.2"
  },
  "keywords": [
    "svelte",
    "kit",
    "websockets",
    "continuous",
    "ws",
    "sveltekit"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "sveltekit-websockets(release): 🚀 v${nextRelease.version}\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
